<script>
var CDN        = "https://cdn.jsdelivr.net/gh/papamamia/77441122@main/1/Build";   /* <-- degistir */
var DATA_PARTS = 9;   /* 70.2MB / 8MB = 9 part */

var buildUrl = CDN;
var config = {
  dataUrl:            null,   /* part'lardan set edilir */
  frameworkUrl:       buildUrl + "/SurvGL.framework.js.unityweb",
  codeUrl:            buildUrl + "/SurvGL.wasm.unityweb",
  streamingAssetsUrl: "StreamingAssets",
  companyName:        "MadStorm",
  productName:        "Forest Survival",
  productVersion:     "1.0"
};

var container        = document.querySelector("#unity-container");
var canvas           = document.querySelector("#unity-canvas");
var loadingCover     = document.querySelector("#loading-cover");
var progressBarFull  = document.querySelector("#unity-progress-bar-full");
var dlStatus         = document.querySelector('#dl-status');

if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent))
  container.className = "unity-mobile";

loadingCover.style.background = "url('https://cdn.jsdelivr.net/gh/papamamia/77441122@main/1/background.png') center / cover";
loadingCover.style.display = "";

/* DATA 0%→55%, Unity 55%→100% */
function setBar(pct, label) {
  progressBarFull.style.width = pct.toFixed(1) + '%';
  if (dlStatus) dlStatus.textContent = label || '';
}

var StartUnityInstance;
var myGameInstance  = null;
var ysdk            = null;
var player          = null;
var payments        = null;
var leaderboard     = null;
var initGame        = false;
var nowFullAdOpen   = false;
var unityStarted    = false;
var cloudSaves      = 'noData';
var paymentsData    = 'none';
var environmentData = 'null';
var playerData      = 'noData';

document.addEventListener('contextmenu', function(e){ e.preventDefault(); });

document.addEventListener('visibilitychange', function(){
  if(ysdk!==null && initGame===true){
    if(document.hidden)
      myGameInstance.SendMessage('YandexGame','OnVisibilityGameWindow','false');
    else
      myGameInstance.SendMessage('YandexGame','OnVisibilityGameWindow','true');
  }
});

function FocusGame(){ window.focus(); canvas.focus(); }
window.addEventListener('pointerdown', function(){ FocusGame(); });
window.addEventListener('touchstart',  function(){ FocusGame(); });

/* Part indirme */
async function fetchDataParts() {
  var parts = [];
  for (var i = 0; i < DATA_PARTS; i++) {
    setBar((i/DATA_PARTS)*55, 'Data indiriliyor... '+(i+1)+'/'+DATA_PARTS+' ('+Math.round((i/DATA_PARTS)*55)+'%)');
    var r = await fetch(buildUrl + '/SurvGL.data.unityweb.part' + i);
    if (!r.ok) throw new Error('part' + i + ' HTTP ' + r.status);
    parts.push(new Uint8Array(await r.arrayBuffer()));
    setBar(((i+1)/DATA_PARTS)*55, 'Data indiriliyor... '+(i+1)+'/'+DATA_PARTS+' ('+Math.round(((i+1)/DATA_PARTS)*55)+'%)');
    console.log('[Data] part'+i+': '+parts[parts.length-1].length+' bytes');
  }
  setBar(55, 'Oyun yükleniyor...');
  var total = parts.reduce(function(s,p){return s+p.length;},0);
  var merged = new Uint8Array(total); var off = 0;
  for(var j=0;j<parts.length;j++){merged.set(parts[j],off);off+=parts[j].length;}
  console.log('[Data] merged: '+total+' bytes');
  return merged;
}
function makeBlobUrl(uint8, filename){
  var blob = new Blob([uint8],{type:'application/octet-stream'});
  return URL.createObjectURL(blob)+'#'+encodeURIComponent(filename);
}

var script = document.createElement("script");
script.src = buildUrl + "/SurvGL.loader.js";
script.onload = async function(){
  try{
    var dataBytes = await fetchDataParts();
    config.dataUrl = makeBlobUrl(dataBytes, "SurvGL.data.unityweb");
  }catch(e){ alert("Download error: "+e.message); return; }

  StartUnityInstance = function(){
    createUnityInstance(canvas, config, function(progress){
      setBar(55+progress*45, progress<1?'Oyun yükleniyor... '+Math.round(55+progress*45)+'%':'');
    }).then(function(inst){
      myGameInstance = inst;
      loadingCover.style.display = "none";
    }).catch(function(msg){ console.error(msg); });
  };

  InitYSDK();
};

function StartUnityInstance_IfUnloaded(){
  if(!unityStarted){
    unityStarted = true;
    StartUnityInstance();
  }
}
function LocalHost(){
  var h=window.location.hostname;
  return h==="localhost"||h==="127.0.0.1";
}

async function InitYSDK(){
  try{
    if(LocalHost()) return;
    console.log('Init Yandex SDK');
    ysdk = await YaGames.init();
    FullAdShow();
    cloudSaves      = await LoadCloud();      console.log('Init Storage ysdk');
    paymentsData    = await GetPayments();    console.log('Init Payments ysdk');
    InitLeaderboards();                       console.log('Init Leaderboards');
    environmentData = await RequestingEnvironmentData(); console.log('Init Envir ysdk');
    playerData      = await InitPlayer();     console.log('Init Player ysdk');
  }catch(e){ console.error('CRASH Init SDK:',e); }
  StartUnityInstance_IfUnloaded();
}

function InitGame(){
  console.log('Init Game Success');
  initGame = true;
  if(nowFullAdOpen===true && myGameInstance!=null)
    myGameInstance.SendMessage('YandexGame','OpenFullAd');
}

function FullAdShow(){
  try{
    if(nowFullAdOpen!==true && ysdk!==null){
      ysdk.adv.showFullscreenAdv({callbacks:{
        onOpen:  function(){ console.log('Open Ad Interstitial'); nowFullAdOpen=true;
          if(initGame) myGameInstance.SendMessage('YandexGame','OpenFullAd'); },
        onClose: function(was){ nowFullAdOpen=false;
          if(initGame) myGameInstance.SendMessage('YandexGame','CloseFullAd',was?'true':'false');
          FocusGame(); },
        onError: function(e){ console.error(e);
          if(myGameInstance) myGameInstance.SendMessage('YandexGame','ErrorFullAd'); FocusGame(); }
      }});
    }
  }catch(e){ console.error('CRASH FullAd:',e.message); }
}

function RewardedShow(id){
  try{
    ysdk.adv.showRewardedVideo({callbacks:{
      onOpen:     function(){ myGameInstance.SendMessage('YandexGame','OpenVideo'); },
      onClose:    function(){ myGameInstance.SendMessage('YandexGame','CloseVideo'); FocusGame(); },
      onRewarded: function(){ myGameInstance.SendMessage('YandexGame','RewardVideo',id); },
      onError:    function(e){ console.error(e); myGameInstance.SendMessage('YandexGame','ErrorVideo'); }
    }});
  }catch(err){ console.error('CRASH Rewarded:',err.message); }
}

function StickyAdActivity(show){
  try{
    ysdk.adv.getBannerAdvStatus().then(function(d){
      if(d.stickyAdvIsShowing){ if(!show) ysdk.adv.hideBannerAdv(); }
      else if(d.reason) console.log('Sticky not shown:',d.reason);
      else if(show) ysdk.adv.showBannerAdv();
    });
  }catch(e){ console.error(e); }
}

function Review(){
  try{
    ysdk.feedback.canReview().then(function(d){
      if(d.value){
        ysdk.feedback.requestReview().then(function(r){
          myGameInstance.SendMessage('YandexGame','ReviewSent',r.feedbackSent?'true':'false');
          FocusGame();
        });
      } else FocusGame();
    });
  }catch(e){ console.error(e); FocusGame(); }
}

function PromptShow(){
  try{
    ysdk.shortcut.showPrompt().then(function(r){
      myGameInstance.SendMessage('YandexGame',r.outcome==='accepted'?'OnPromptSuccess':'OnPromptFail');
      FocusGame();
    });
  }catch(e){ console.error(e); FocusGame(); }
}

function SaveCloud(jsonData,flush){
  if(!player){ console.error('CRASH Save Cloud: no player'); return; }
  try{ player.setData({saves:[jsonData]},flush); }catch(e){ console.error(e); }
}
function LoadCloud(sendback){
  return new Promise(function(resolve){
    if(!ysdk){ if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData'); resolve('noData'); return; }
    try{
      ysdk.getPlayer({scopes:false}).then(function(_p){
        _p.getData(["saves"]).then(function(data){
          var r=data.saves?JSON.stringify(data.saves):'noData';
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves',r);
          resolve(r);
        }).catch(function(){ if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData'); resolve('noData'); });
      }).catch(function(e){ console.error(e); if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetLoadSaves','noData'); resolve('noData'); });
    }catch(e){ console.error(e); resolve('noData'); }
  });
}

function GetPayments(sendback){
  return new Promise(function(resolve){
    try{
      if(!ysdk){ resolve('none'); return; }
      ysdk.getPayments().then(function(_p){
        payments=_p;
        _p.getCatalog().then(function(products){
          _p.getPurchases().then(function(purchases){
            var ids=[],titles=[],descs=[],imgs=[],prices=[],pvals=[],codes=[],imgURLs=[],cons=[];
            for(var i=0;i<products.length;i++){
              ids[i]=products[i].id;titles[i]=products[i].title;descs[i]=products[i].description;
              imgs[i]=products[i].imageURI;prices[i]=products[i].price;pvals[i]=products[i].priceValue;
              codes[i]=products[i].priceCurrencyCode;imgURLs[i]=products[i].getPriceCurrencyImage("medium");
              cons[i]=!purchases.some(function(p){return p.productID===ids[i];});
            }
            var j=JSON.stringify({id:ids,title:titles,description:descs,imageURI:imgs,price:prices,
              priceValue:pvals,priceCurrencyCode:codes,currencyImageURL:imgURLs,consumed:cons,
              language:ysdk.environment.i18n.lang});
            if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','PaymentsEntries',j);
            resolve(j);
          });
        });
      }).catch(function(e){ console.log('Purchases not available',e.message); resolve('none'); });
    }catch(e){ console.error(e); resolve('none'); }
  });
}
function BuyPayments(id){
  try{
    if(payments){ payments.purchase(id).then(function(){console.log('Purchase Success');ConsumePurchase(id);FocusGame();})
      .catch(function(e){console.error(e);myGameInstance.SendMessage('YandexGame','OnPurchaseFailed',id);FocusGame();}); }
    else console.log('Payments == null');
  }catch(e){console.error(e);FocusGame();}
}
function ConsumePurchase(id){
  try{
    if(payments) payments.getPurchases().then(function(ps){
      for(var i=0;i<ps.length;i++) if(ps[i].productID===id){
        payments.consumePurchase(ps[i].purchaseToken);
        myGameInstance.SendMessage('YandexGame','OnPurchaseSuccess',id);
      }
    });
  }catch(e){console.error(e);}
}
function ConsumePurchases(){
  try{
    if(payments) payments.getPurchases().then(function(ps){
      console.log('Unprocessed:',ps.length);
      for(var i=0;i<ps.length;i++){
        payments.consumePurchase(ps[i].purchaseToken);
        myGameInstance.SendMessage('YandexGame','OnPurchaseSuccess',ps[i].productID);
      }
    });
  }catch(e){console.error(e);}
}
function InitLeaderboards(){
  ysdk.getLeaderboards().then(function(_lb){ leaderboard=_lb; });
}
function WaitForLeaderboard(){
  return new Promise(function(resolve,reject){
    var iv=setInterval(function(){if(leaderboard!==null){clearInterval(iv);clearTimeout(to);resolve();}},100);
    var to=setTimeout(function(){clearInterval(iv);reject(new Error("LB timeout"));},5000);
  });
}
async function GetLeaderboardScores(nameLB,maxPlayers,quantityTop,quantityAround,photoSize,auth){
  try{
    if(!leaderboard) await WaitForLeaderboard();
    var j={technoName:'',isDefault:false,isInvertSortOrder:false,decimalOffset:0,type:''};
    ysdk.getLeaderboards().then(function(lb){ return lb.getLeaderboardDescription(nameLB); })
    .then(function(res){
      j.technoName=nameLB;j.isDefault=res.default;
      j.isInvertSortOrder=res.description.invert_sort_order;
      j.decimalOffset=res.description.score_format.options.decimal_offset;
      j.type=res.description.type;
      return leaderboard.getLeaderboardEntries(nameLB,{quantityTop:quantityTop,includeUser:auth,quantityAround:quantityAround});
    }).then(function(res){
      myGameInstance.SendMessage('YandexGame','LeaderboardEntries',JSON.stringify(Object.assign({},j,EntriesLB(res,maxPlayers,photoSize))));
    }).catch(function(e){console.error(e);});
  }catch(e){console.error(e);}
}
async function SetLeaderboardScores(name,score){
  try{
    if(!leaderboard) await WaitForLeaderboard();
    ysdk.getLeaderboards().then(function(lb){lb.setLeaderboardScore(name,score);});
  }catch(e){console.error(e);}
}
function EntriesLB(res,maxPlayers,photoSize){
  var n=Math.min(res.entries.length,maxPlayers),txt='',ranks=[],photos=[],names=[],scores=[],uids=[];
  for(var i=0;i<n;i++){
    ranks[i]=res.entries[i].rank;scores[i]=res.entries[i].score;uids[i]=res.entries[i].player.uniqueID;
    photos[i]=res.entries[i].player.getAvatarSrc(photoSize);
    names[i]=res.entries[i].player.scopePermissions.public_name==='allow'?res.entries[i].player.publicName:'anonymous';
    txt+=ranks[i]+'. '+names[i]+': '+scores[i]+'\n';
  }
  return{entries:n===0?'no data':txt,ranks:ranks,photos:photos,names:names,scores:scores,uniqueIDs:uids};
}
function RequestingEnvironmentData(sendback){
  return new Promise(function(resolve){
    if(!ysdk){ resolve('null'); return; }
    try{
      var promptCanShow=false,reviewCanShow=false;
      ysdk.feedback.canReview().then(function(d){
        if(d.value) reviewCanShow=true;
        ysdk.shortcut.canShowPrompt().then(function(p){
          if(p.canShow) promptCanShow=true;
          var ua=navigator.userAgent,browser;
          if(ua.includes('YaBrowser')||ua.includes('YaSearchBrowser')) browser='Yandex';
          else if(ua.includes('Opera')||ua.includes('OPR')) browser='Opera';
          else if(ua.includes('Firefox')) browser='Firefox';
          else if(ua.includes('MSIE')) browser='IE';
          else if(ua.includes('Edge')) browser='Edge';
          else if(ua.includes('Chrome')) browser='Chrome';
          else if(ua.includes('Safari')) browser='Safari';
          else browser='Other';
          var j=JSON.stringify({
            language:ysdk.environment.i18n.lang,domain:ysdk.environment.i18n.tld,
            deviceType:ysdk.deviceInfo.type,isMobile:ysdk.deviceInfo.isMobile(),
            isDesktop:ysdk.deviceInfo.isDesktop(),isTablet:ysdk.deviceInfo.isTablet(),
            isTV:ysdk.deviceInfo.isTV(),appID:ysdk.environment.app.id,
            browserLang:ysdk.environment.browser.lang,payload:ysdk.environment.payload,
            promptCanShow:promptCanShow,reviewCanShow:reviewCanShow,
            platform:navigator.platform,browser:browser
          });
          environmentData=j;
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetEnvirData',j);
          resolve(j); console.log("Environment Data: "+j);
        });
      });
    }catch(e){console.error(e);resolve('null');}
  });
}
function InitPlayer(sendback){
  return new Promise(function(resolve){
    try{
      if(!ysdk){
        var r=NotAuthorized();
        if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
        resolve(r); return;
      }
      ysdk.getPlayer({scopes:true}).then(function(_p){
        player=_p;
        if(player.getMode()==='lite'){
          var r=NotAuthorized();
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
          resolve(r);
        } else {
          var j=JSON.stringify({playerAuth:'resolved',playerName:player.getName(),
            playerId:player.getUniqueID(),playerPhoto:player.getPhoto('small'),
            payingStatus:player.getPayingStatus()});
          if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',j);
          resolve(j);
        }
      }).catch(function(e){
        console.error(e);
        var r=NotAuthorized();
        if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
        resolve(r);
      });
    }catch(e){
      console.error(e);
      var r=NotAuthorized();
      if(sendback&&myGameInstance) myGameInstance.SendMessage('YandexGame','SetInitializationSDK',r);
      resolve(r);
    }
  });
}
function NotAuthorized(){
  return JSON.stringify({playerAuth:'rejected',playerName:'unauthorized',
    playerId:'unauthorized',playerPhoto:'unknown',payingStatus:'unknown'});
}
function OpenAuthDialog(){
  if(!ysdk) return;
  try{
    ysdk.auth.openAuthDialog().then(function(){
      InitPlayer(true).then(function(){myGameInstance.SendMessage('YandexGame','GetDataInvoke');});
    });
  }catch(e){console.log('CRASH Open Auth Dialog:',e.message);}
}

document.body.appendChild(script);
</script>
<!-- Sticky Bottom Center Ad (728x90) with Smooth Slide-Out and Reappearance -->
<style>
  /* Container: Bottom center, fixed, with overflow hidden */
  #ad-container {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(728px, calc(100% - 20px)); /* 728px, 10px margin on mobile */
    height: 90px;
    background: rgba(0, 0, 0, 0.90);
    display: none;
    z-index: 99999;
    border-radius: 0; /* Sharp corners */
    overflow: hidden;
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.45);
    box-sizing: border-box;
    transition: transform 0.5s ease-in-out; /* Smooth slide-in/out animation */
  }

  /* Slide-out animation */
  #ad-container.hidden {
    transform: translate(-50%, 100%); /* Slide down out of view */
  }

  #ad-iframe {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 745px; /* Updated width */
    height: 90px; /* Updated height */
    border: 0;
    display: block;
    overflow: hidden;
    pointer-events: auto;
    box-sizing: content-box;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  #ad-iframe::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  /* Close button with arrow */
  #close-ad {
    position: absolute;
    top: 6px;
    right: 8px;
    background: #ff4d4d;
    color: #fff;
    border: none;
    padding: 5px 9px;
    font-size: 13px;
    border-radius: 4px;
    cursor: not-allowed;
    opacity: 0.72;
    z-index: 100000;
    display: flex;
    align-items: center;
  }
  #close-ad.enabled {
    cursor: pointer;
    opacity: 1;
  }
  #close-ad::before {
    content: '↓'; /* Down arrow for bottom ad */
    margin-right: 4px;
  }

  /* Right mask for scrollbar */
  #ad-right-mask {
    position: absolute;
    top: 0;
    right: 0;
    width: 12px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.9));
    z-index: 99999;
  }

  /* Mobile adjustments */
  @media (max-width: 440px) {
    #ad-container {
      width: calc(100% - 12px);
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0; /* Sharp corners on mobile */
    }
    #ad-iframe {
      width: 728px;
    }
  }
</style>

<div id="ad-container" aria-hidden="true" role="dialog" aria-label="Advertisement">
  <iframe
    id="ad-iframe"
    src="https://script.google.com/macros/s/AKfycbyLqfuYNg4HqY0inO1-UyYb5pVvsb0FDxHj6mw418ypqPmoNzUgt0McBC9Q9JfLfFp39Q/exec"
    width="768px"
    height="95px"
    scrolling="no"
    frameborder="0"
    sandbox="allow-scripts allow-popups allow-same-origin"
  ></iframe>
  <button id="close-ad" disabled>Close (12)</button>
  <div id="ad-right-mask"></div>
</div>

<script>
  (function () {
    const showDelay = 2000; // 2 seconds delay before first show
    const countdownStart = 12; // 12 seconds countdown
    const reappearDelay = 150000; // 25 seconds before reappearance
    const adContainer = document.getElementById('ad-container');
    const closeBtn = document.getElementById('close-ad');

    function showAd() {
      // Show ad with smooth slide-in
      adContainer.style.display = 'block';
      adContainer.classList.remove('hidden');
      adContainer.setAttribute('aria-hidden', 'false');

      // Start countdown
      let timeLeft = countdownStart;
      closeBtn.textContent = `Close (${timeLeft})`;
      closeBtn.disabled = true;
      closeBtn.classList.remove('enabled');

      const t = setInterval(() => {
        timeLeft--;
        if (timeLeft > 0) {
          closeBtn.textContent = `Close (${timeLeft})`;
        } else {
          clearInterval(t);
          closeBtn.disabled = false;
          closeBtn.classList.add('enabled');
          closeBtn.textContent = 'Close ↓';
        }
      }, 1000);
    }

    // Initial ad show
    setTimeout(showAd, showDelay);

    // Close with animation and schedule reappearance
    closeBtn.addEventListener('click', () => {
      if (closeBtn.disabled) return;
      adContainer.classList.add('hidden');
      adContainer.setAttribute('aria-hidden', 'true');
      // Schedule reappearance without removing or reloading iframe
      setTimeout(showAd, reappearDelay);
    });
  })();
</script>
